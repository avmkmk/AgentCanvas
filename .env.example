# AgentCanvas — Environment Variables Template
# Copy to .env and fill in your actual values
# NEVER commit .env — only .env.example belongs in version control
# Issue: D-02

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_in_env
POSTGRES_DB=orchestrator
DATABASE_URL=postgresql+asyncpg://admin:changeme_in_env@postgres:5432/orchestrator

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_USER=admin
MONGODB_PASSWORD=changeme_in_env
MONGODB_DB=orchestrator
MONGO_URI=mongodb://admin:changeme_in_env@mongodb:27017/orchestrator?authSource=admin

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API Security ──────────────────────────────────────────────────────────────
# Change this to a strong random string in production
API_KEY=dev-api-key-changeme

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins — never use wildcard (*)
ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── LLM Behaviour ─────────────────────────────────────────────────────────────
MAX_LLM_RETRIES=3
LLM_TIMEOUT_SECONDS=30
